<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ttrss.module.feed.mapper.FeedCategoryMapper">

    <resultMap id="BaseResultMap" type="com.ttrss.module.feed.entity.FeedCategory">
        <id column="id" property="id"/>
        <result column="owner_uid" property="ownerUid"/>
        <result column="title" property="title"/>
        <result column="parent_cat" property="parentCat"/>
        <result column="order_id" property="orderId"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <!-- 根据用户 ID 查询分类列表 -->
    <select id="selectByOwnerUid" resultMap="BaseResultMap">
        SELECT id, owner_uid, title, parent_cat, order_id, created_at, updated_at
        FROM ttrss_feed_categories
        WHERE owner_uid = #{ownerUid}
        ORDER BY order_id ASC, title ASC
    </select>

    <!-- 根据父分类 ID 查询子分类 -->
    <select id="selectByParentCat" resultMap="BaseResultMap">
        SELECT id, owner_uid, title, parent_cat, order_id, created_at, updated_at
        FROM ttrss_feed_categories
        WHERE parent_cat = #{parentCat}
        ORDER BY order_id ASC, title ASC
    </select>

</mapper>
