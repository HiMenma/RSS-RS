# Docker Compose 环境配置模板
# 复制此文件为 .env 并根据需要修改
# cp .env.example .env

# ===========================================
# PostgreSQL 数据库配置
# ===========================================
POSTGRES_VERSION=15
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ttrss
POSTGRES_PORT=5432

# ===========================================
# 后端 Spring Boot 配置
# ===========================================
BACKEND_PORT=8080
BACKEND_IMAGE_NAME=ttrss-backend

# 数据库连接 (Docker 网络内部使用)
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/ttrss
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# Spring 激活配置（可选值：dev, prod）
SPRING_PROFILES_ACTIVE=dev

# 日志配置
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_TTRSS=DEBUG

# ===========================================
# JWT 认证配置（生产环境必须修改）
# ===========================================
# ⚠️ 生产环境必须修改为安全的随机字符串！
# 生成方法：openssl rand -base64 32
JWT_SECRET=your-very-secure-random-key-minimum-32-characters
JWT_EXPIRATION=900000           # JWT 令牌有效期（毫秒），默认 15 分钟
JWT_REFRESH_EXPIRATION=604800000 # 刷新令牌有效期（毫秒），默认 7 天

# ===========================================
# 前端 Vite 开发服务器配置
# ===========================================
FRONTEND_PORT=3000
FRONTEND_IMAGE_NAME=ttrss-frontend
VITE_API_BASE_URL=http://localhost:8080

# 前端开发服务器监听地址
VITE_HOST=0.0.0.0

# 文件监听配置（Docker 内需要）
CHOKIDAR_USEPOLLING=true
WATCHPACK_POLLING=true

# ===========================================
# HTTP 端口 (Web 访问)
# ===========================================
HTTP_PORT=8280

# ===========================================
# 调度器配置（Feed 自动更新）
# ===========================================
SCHEDULER_ENABLED=true          # 是否启用调度器
SCHEDULER_FIXED_DELAY=300000    # 执行间隔（毫秒），默认 5 分钟
SCHEDULER_INITIAL_DELAY=60000   # 初始延迟（毫秒），默认 1 分钟

# ===========================================
# JVM 配置（可选）
# ===========================================
JAVA_OPTS=-Xmx512m -Xms256m     # JVM 内存参数
